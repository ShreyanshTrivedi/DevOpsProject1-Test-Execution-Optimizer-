pipeline {
    agent any

    parameters {
        choice(name: 'STRATEGY', choices: ['time_based', 'priority_based', 'hybrid'], description: 'Optimization strategy')
        string(name: 'MAX_PARALLEL', defaultValue: '4', description: 'Maximum parallel tests')
    }

    environment {
        DOCKER_IMAGE = 'test-optimizer'
        VERSION = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Code Quality') {
            steps {
                script {
                    sh 'pip install flake8 pylint black'
                    sh 'flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics || true'
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    sh 'pip install -r requirements.txt'
                    sh 'python -m py_compile main.py test_optimizer.py test_optimizer_api.py'
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    sh 'pip install pytest pytest-cov'
                    sh 'python -m pytest tests/unit/ -v --cov=. --cov-report=xml --cov-report=term || true'
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    sh 'docker build -f infrastructure/docker/Dockerfile -t ${DOCKER_IMAGE}:${VERSION} . || true'
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                expression { env.BRANCH_NAME == 'develop' }
            }
            steps {
                script {
                    sh 'docker-compose -f infrastructure/docker/docker-compose.yml up -d'
                }
            }
        }

        stage('Deploy to Production') {
            when {
                expression { env.BRANCH_NAME == 'main' }
            }
            steps {
                input message: 'Deploy to production?', ok: 'Deploy'
                script {
                    sh 'docker-compose -f infrastructure/docker/docker-compose.yml up -d'
                }
            }
            post {
                success {
                    echo 'Deployment successful!'
                }
                failure {
                    echo 'Deployment failed!'
                }
            }
        }
    }

    post {
        always {
            junit '**/test-results/*.xml'
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'htmlcov',
                reportFiles: 'index.html',
                reportName: 'Coverage Report'
            ])
        }
        success {
            emailext(
                subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build completed successfully.\n\nBuild URL: ${env.BUILD_URL}",
                to: 'developer@example.com'
            )
        }
        failure {
            emailext(
                subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build failed. Please check logs.\n\nBuild URL: ${env.BUILD_URL}",
                to: 'developer@example.com'
            )
        }
    }
}